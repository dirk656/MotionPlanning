<?xml version="1.0" encoding="utf-8"?>
<robot name="fp3">

  <!-- ==================== Materials ==================== -->
  <material name="link_color">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="joint_color">
    <color rgba="1.0 0.55 0.0 1.0"/>
  </material>
  <material name="ee_color">
    <color rgba="0.2 0.8 0.2 1.0"/>
  </material>

  <!-- ==================== Links ==================== -->

  <!-- Base link -->
  <link name="base"/>

  <!-- Link 0: base → joint1, offset (0,0,0.333), cylinder along z -->
  <link name="link0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.1665" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.333"/>
      </geometry>
      <material name="link_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1665" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.333"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0172 0.0004 0.0745" rpy="0 0 0"/>
      <mass value="2.3966"/>
      <inertia ixx="0.0090" ixy="0.0000" ixz="0.0020"
               iyy="0.0115" iyz="0.0000" izz="0.0085"/>
    </inertial>
  </link>

  <!-- Link 1: joint1→joint2, offset (0,0,0), zero-length → sphere only -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0000004128 -0.0181251324 -0.0386035970" rpy="0 0 0"/>
      <mass value="2.9274653454"/>
      <inertia ixx="0.023927316485107913" ixy="1.3317903455714081e-05" ixz="-0.00011404774918616684"
               iyy="0.0224821613275756" iyz="-0.0019950320628240115" izz="0.006350098258530016"/>
    </inertial>
  </link>

  <!-- Link 2: joint2→joint3, offset (0,-0.316,0), cylinder along -y -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <visual>
      <origin xyz="0 -0.158 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.316"/>
      </geometry>
      <material name="link_color"/>
    </visual>
    <collision>
      <origin xyz="0 -0.158 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.316"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0031828864 -0.0743221644 0.0088146084" rpy="0 0 0"/>
      <mass value="2.9355370338"/>
      <inertia ixx="0.041938946257609425" ixy="0.00020257331521090626" ixz="0.004077784227179924"
               iyy="0.02514514885014724" iyz="-0.0042252158006570156" izz="0.06170214472888839"/>
    </inertial>
  </link>

  <!-- Link 3: joint3→joint4, offset (0.0825,0,0), cylinder along x -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <visual>
      <origin xyz="0.04125 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.0825"/>
      </geometry>
      <material name="link_color"/>
    </visual>
    <collision>
      <origin xyz="0.04125 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.0825"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0407015686 -0.0048200565 -0.0289730823" rpy="0 0 0"/>
      <mass value="2.2449013699"/>
      <inertia ixx="0.02410142547240885" ixy="0.002404694559042109" ixz="-0.002856269270114313"
               iyy="0.01974053266708178" iyz="-0.002104212683891874" izz="0.019044494482244823"/>
    </inertial>
  </link>

  <!-- Link 4: joint4→joint5, offset (-0.0825,0.384,0), length≈0.393, cylinder along offset direction -->
  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <visual>
      <origin xyz="-0.04125 0.192 0" rpy="0 1.5708 -1.3587"/>
      <geometry>
        <cylinder radius="0.035" length="0.393"/>
      </geometry>
      <material name="link_color"/>
    </visual>
    <collision>
      <origin xyz="-0.04125 0.192 0" rpy="0 1.5708 -1.3587"/>
      <geometry>
        <cylinder radius="0.035" length="0.393"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0459100965 0.0630492960 -0.0085187868" rpy="0 0 0"/>
      <mass value="2.6155955791"/>
      <inertia ixx="0.03452998321913202" ixy="0.01322552265982813" ixz="0.01015142998484113"
               iyy="0.028881621933049058" iyz="-0.0009762833870704552" izz="0.04125471171146641"/>
    </inertial>
  </link>

  <!-- Link 5: joint5→joint6, offset (0,0,0), zero-length → sphere only -->
  <link name="link5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0016039605 0.0292536262 -0.0972965990" rpy="0 0 0"/>
      <mass value="2.3271207594"/>
      <inertia ixx="0.051610278463662895" ixy="-0.005715173387783472" ixz="-0.0035673167625872135"
               iyy="0.04787729713371481" iyz="0.010673985108535986" izz="0.016423625579357254"/>
    </inertial>
  </link>

  <!-- Link 6: joint6→joint7, offset (0.088,0,0), cylinder along x -->
  <link name="link6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <visual>
      <origin xyz="0.044 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.088"/>
      </geometry>
      <material name="link_color"/>
    </visual>
    <collision>
      <origin xyz="0.044 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.088"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0597131221 -0.0410294666 -0.0101692726" rpy="0 0 0"/>
      <mass value="1.8170376524"/>
      <inertia ixx="0.005412333594383447" ixy="0.006193456360285834" ixz="0.0014219289306117652"
               iyy="0.014058329545509979" iyz="-0.0013140753741120031" izz="0.016080817924212554"/>
    </inertial>
  </link>

  <!-- Link 7 (flange): joint7→joint8, offset (0,0,0.107), cylinder along z -->
  <link name="link7">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_color"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.0535" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.107"/>
      </geometry>
      <material name="link_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0535" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.107"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0045225817 0.0086261921 -0.0161633251" rpy="0 0 0"/>
      <mass value="0.6271432862"/>
      <inertia ixx="0.00021092389150104718" ixy="-2.433299114461931e-05" ixz="4.564480393778983e-05"
               iyy="0.00017718568002411474" iyz="8.744070223226438e-05" izz="5.993190599659971e-05"/>
    </inertial>
  </link>

  <!-- Link 8 (end-effector mounting point) -->
  <link name="link8">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="ee_color"/>
    </visual>
  </link>

  <!-- ==================== Joints ==================== -->

  <!-- Fixed joint: base -> link0 -->
  <joint name="base_joint" type="fixed">
    <parent link="base"/>
    <child link="link0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Joint 1: link0 -> link1 -->
  <joint name="joint1" type="revolute">
    <parent link="link0"/>
    <child link="link1"/>
    <origin xyz="0 0 0.333" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9007" upper="2.9007" velocity="2.62" effort="87.0"/>
  </joint>

  <!-- Joint 2: link1 -> link2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="-1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.8361" upper="1.8361" velocity="2.62" effort="87.0"/>
  </joint>

  <!-- Joint 3: link2 -> link3 -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.316 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9007" upper="2.9007" velocity="2.62" effort="87.0"/>
  </joint>

  <!-- Joint 4: link3 -> link4 -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.0825 0 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0770" upper="-0.1169" velocity="2.62" effort="87.0"/>
  </joint>

  <!-- Joint 5: link4 -> link5 -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="-0.0825 0.384 0" rpy="-1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8763" upper="2.8763" velocity="5.26" effort="12.0"/>
  </joint>

  <!-- Joint 6: link5 -> link6 -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.4398" upper="4.6216" velocity="4.18" effort="12.0"/>
  </joint>

  <!-- Joint 7: link6 -> link7 -->
  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="0.088 0 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0508" upper="3.0508" velocity="5.26" effort="12.0"/>
  </joint>

  <!-- Joint 8 (fixed): link7 -> link8 (flange) -->
  <joint name="joint8" type="fixed">
    <parent link="link7"/>
    <child link="link8"/>
    <origin xyz="0 0 0.107" rpy="0 0 0"/>
  </joint>

</robot>
